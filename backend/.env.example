MINIMAX_API_KEY=your_api_key_here
MINIMAX_BASE_URL=https://api.minimaxi.com/v1
GROQ_API_KEY=your_groq_api_key_here
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_TRANSCRIPTION_MODEL=whisper-large-v3
GROQ_MAX_UPLOAD_MB=24
WHISPER_MODEL_SIZE=large-v3
DATABASE_URL=mysql+mysqlconnector://asr_user:asr_password@127.0.0.1:3307/asr_meeting
UPLOAD_DIR=./data/uploads
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=your_smtp_username
SMTP_PASSWORD=your_smtp_password
SMTP_FROM_EMAIL=no-reply@example.com
SMTP_FROM_NAME=Audio Memo
SMTP_USE_TLS=true
SUMMARY_EMAIL_AUTO_SEND=false
AI_RUNTIME_ENABLED=true
SUMMARY_ENGINE=legacy
QA_ENGINE=langgraph
VECTOR_STORE_DIR=./data/vectorstore
CHAT_PROVIDER=minimax
CHAT_MODEL_SUMMARY=MiniMax-M2.5
CHAT_MODEL_QA=MiniMax-M2.5
EMBEDDING_PROVIDER=sentence_transformers
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
EMBEDDING_DEVICE=cpu
QA_REQUIRE_REAL_EMBEDDINGS=true
QA_RETRIEVAL_TOP_K=10
QA_KEYWORD_TOP_K=8
QA_RERANK_TOP_N=4
QA_NEIGHBOR_WINDOW=1
OPENAI_API_KEY=
OPENAI_BASE_URL=
